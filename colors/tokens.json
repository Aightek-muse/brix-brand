{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "BRIX Money Design Tokens",
  "version": "1.0.0",
  "description": "Official design tokens for BRIX Money brand",
  "tokens": {
    "color": {
      "primary": {
        "orange": {
          "value": "#DF7032",
          "type": "color",
          "description": "Primary accent — emerging-market energy"
        }
      },
      "neutral": {
        "nightly": {
          "value": "#0B0B0B",
          "type": "color",
          "description": "Deep black-slate — institutional stability"
        },
        "white": {
          "value": "#FFFFFF",
          "type": "color",
          "description": "Transparency, clean foreground"
        },
        "platinum": {
          "value": "#E6E6E6",
          "type": "color",
          "description": "Neutral support/background"
        }
      },
      "gradient": {
        "primary": {
          "value": "linear-gradient(to bottom, #FFFFFF, #DF7032)",
          "type": "gradient",
          "description": "White to Orange linear gradient"
        }
      }
    },
    "typography": {
      "fontFamily": {
        "display": {
          "value": "Founders Grotesk",
          "type": "fontFamily",
          "description": "Main title/display font"
        },
        "body": {
          "value": "Urbanist",
          "type": "fontFamily",
          "description": "Body text and system UI"
        },
        "accent": {
          "value": "Nyght Serif",
          "type": "fontFamily",
          "description": "Editorial and premium moments"
        }
      }
    }
  }
}
